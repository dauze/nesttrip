{
  "firestore": {
    "database": "(default)",
    "location": "europe-west9",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "rewrites": [
      { "source": "/api/**", "function": "api" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
    "npm --prefix \"$RESOURCE_DIR\" install",
    "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  }
}
